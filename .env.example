# ===================================
# Configuration Environnement Production
# CJD Amiens - cjd80.fr
# ===================================

# Node Environment
NODE_ENV=production
PORT=5000

# ===================================
# Database (PostgreSQL)
# ===================================
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://username:password@localhost:5432/cjd_amiens

# Superuser PostgreSQL pour les migrations DDL (ALTER TABLE, CREATE INDEX...)
# Obligatoire si DATABASE_URL n'est pas le owner des tables (user applicatif restreint)
# Format: postgresql://postgres:password@localhost:5432/cjd_amiens
DATABASE_URL_SUPERUSER=postgresql://postgres:password@localhost:5432/cjd_amiens

# ===================================
# Session Security
# ===================================
# Générez une clé secrète forte avec: openssl rand -base64 32
SESSION_SECRET=your-secret-session-key-change-this

# ===================================
# Authentication
# ===================================
# Auth mode: local (via @robinswood/auth-unified)
AUTH_MODE=local
# Dev login (development only): enables password bypass with "dev-login" strategy
ENABLE_DEV_LOGIN=true

# ===================================
# Email (SMTP Configuration)
# ===================================
SMTP_USER=your-email@example.com
SMTP_PASSWORD=your-smtp-password

# ===================================
# GitHub Integration
# ===================================
# Pour la synchronisation des demandes de développement
GITHUB_TOKEN=ghp_your_github_token
GITHUB_REPO_OWNER=Aoleon
GITHUB_REPO_NAME=cjd80

# ===================================
# Push Notifications (VAPID)
# ===================================
# Générez les clés VAPID avec: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_MAILTO=mailto:admin@cjd80.fr

# ===================================
# Notes de déploiement
# ===================================
# 1. Copiez ce fichier vers .env et remplissez avec vos vraies valeurs
# 2. NE JAMAIS committer le fichier .env dans Git
# 3. Sur le VPS, placez .env dans le répertoire de l'application
# 4. Docker compose chargera automatiquement ces variables
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_EXTERNAL_PORT=9002
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_LOAN_ITEMS=loan-items
MINIO_BUCKET_ASSETS=assets
