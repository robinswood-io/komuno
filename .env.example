# ===================================
# Komuno - Example environment file
# Copy to .env and adapt values
# ===================================

# Runtime
NODE_ENV=production
PORT=5000

# ===================================
# Database (PostgreSQL)
# ===================================
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://username:password@localhost:5432/komuno

# Optional: superuser URL for DDL migrations
DATABASE_URL_SUPERUSER=postgresql://postgres:password@localhost:5432/komuno

# ===================================
# Session Security
# ===================================
# Generate with: openssl rand -base64 48
SESSION_SECRET=change-this-session-secret

# ===================================
# Authentication
# ===================================
# local or oauth
AUTH_MODE=local
# Enable only in development
ENABLE_DEV_LOGIN=false

# ===================================
# Email (optional)
# ===================================
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASSWORD=your-smtp-password
SMTP_FROM=noreply@example.com

# ===================================
# GitHub Integration (optional)
# ===================================
GITHUB_TOKEN=ghp_xxx
GITHUB_REPO_OWNER=your-org
GITHUB_REPO_NAME=komuno

# ===================================
# Push Notifications (optional)
# ===================================
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_MAILTO=mailto:admin@example.com

# ===================================
# Object Storage (MinIO/S3)
# ===================================
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_EXTERNAL_PORT=9002
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=change-me
MINIO_BUCKET_LOAN_ITEMS=loan-items
MINIO_BUCKET_ASSETS=assets

S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=change-me

# ===================================
# Logging / monitoring (optional)
# ===================================
LOKI_HOST=
LOG_LEVEL=info
