# =============================================================================
# Komuno production environment (example)
# Copy this file to .env and set real values
# =============================================================================

# Application
APP_NAME=komuno
DOMAIN=example.org
NODE_ENV=production

# PostgreSQL
DATABASE_URL=postgresql://appuser:CHANGE_ME@postgres:5432/komuno
DB_USER=appuser
DB_PASSWORD=CHANGE_ME
DB_NAME=komuno

# Redis
REDIS_URL=redis://redis:6379

# MinIO / S3
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=CHANGE_ME
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=CHANGE_ME

# Session
SESSION_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL

# Public URLs
NEXT_PUBLIC_BACKEND_URL=https://example.org
NEXT_PUBLIC_MINIO_ENDPOINT=minio.example.org

# Email (optional)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@example.org

# Monitoring (optional)
LOKI_HOST=
LOG_LEVEL=info
