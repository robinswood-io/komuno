# Komuno demo image.
#
# The demo stack rebuilds this small image on the PROD server. It always pulls the
# latest published Komuno runtime image, then enables demo mode through env vars in
# docker-compose.demo.yml. Demo-mode code is part of the application itself, so no
# compiled auth files are patched here.

ARG KOMUNO_BASE_IMAGE=ghcr.io/robinswood-io/komuno:latest
FROM ${KOMUNO_BASE_IMAGE}
