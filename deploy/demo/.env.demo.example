# Komuno demo instance — copy to .env.demo on the server.
DOMAIN=demo.komuno.org
APP_NAME=komuno-demo

DB_USER=komuno_demo
DB_PASSWORD=change-this-demo-db-password
DB_NAME=komuno_demo

SESSION_SECRET=change-this-demo-session-secret-at-least-32-chars
KOMUNO_DEMO_MODE=true
KOMUNO_DEMO_ADMIN_EMAIL=demo@komuno.fr

AUTH_MODE=local
ENABLE_DEV_LOGIN=false

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-this-demo-minio-password
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=change-this-demo-minio-password
MINIO_BUCKET_LOAN_ITEMS=loan-items
MINIO_BUCKET_ASSETS=assets
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=change-this-demo-minio-password

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@demo.komuno.fr
LOG_LEVEL=info

# Demo auto-update scheduler.
# The updater checks GitHub periodically, but deploys/builds at most once per 24h.
KOMUNO_DEMO_REPO_URL=https://github.com/robinswood-io/komuno.git
KOMUNO_DEMO_BRANCH=main
KOMUNO_DEMO_MIN_INTERVAL_SECONDS=86400
KOMUNO_DEMO_UPDATE_CHECK_INTERVAL_SECONDS=3600
KOMUNO_DEMO_RESET_INTERVAL_SECONDS=3600
